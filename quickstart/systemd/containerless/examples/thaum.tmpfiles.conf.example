# Install to /etc/tmpfiles.d/thaum.conf
# Creates the runtime directory for the Unix socket before gunicorn starts.
d /run/thaum 0750 thaum thaum -
# App logs (thaum user); PostgreSQL file logging should use log_directory under postgresql/.
d /var/log/thaum 0755 thaum thaum -
d /var/log/thaum/postgresql 0750 postgres postgres -

[Service]
# If thaum.conf omits [server.database].db_url (bundled PostgreSQL in the container), omit the
# thaum_db_url line below and do not create /etc/credstore.encrypted/thaum_db_url.
LoadCredentialEncrypted=thaum_db_url:/etc/credstore.encrypted/thaum_db_url
LoadCredentialEncrypted=thaum_database_vault_passphrase:/etc/credstore.encrypted/thaum_database_vault_passphrase
LoadCredentialEncrypted=atlassian-api-token:/etc/credstore.encrypted/atlassian-api-token
LoadCredentialEncrypted=thaum_webex_token_database:/etc/credstore.encrypted/thaum_webex_token_database

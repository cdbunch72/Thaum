# Thaum quickstart example — copy to /etc/thaum/thaum.conf and adjust.
#
# [server.database].db_url:
# - Container image with bundled PostgreSQL: you may omit `db_url` to use the default Unix-socket
#   URL (see docs/ARCHITECTURE.md). Then remove `thaum_db_url` from systemd credentials and from
#   thaum.service.d/credentials.conf.
# - Or keep `db_url = "secret:thaum_db_url"` and put the bundled URL or an external DSN in the
#   thaum_db_url credential. Bundled URL:
#   postgresql+psycopg://thaum@/thaum?host=/tmp/postgres&client_encoding=utf8
#
# Omit-db_url variant (bundled PG in container) — use this OR the active [server.database] below:
# [server.database]
# database_vault_passphrase = "secret:thaum_database_vault_passphrase"
# data_key_rotate_days = 60

[server]
base_url = "https://thaum.example.com"
bot_type = "webex"
lookup_plugin = "atlassian"

[server.database]
db_url = "secret:thaum_db_url"
database_vault_passphrase = "secret:thaum_database_vault_passphrase"
data_key_rotate_days = 60

[logging]
level = "INFO"
file = true
file_backup_count = 5

# Shared Atlassian Cloud identity (merged into [lookup.atlassian] via connection_ref).
# Use the same api_token secret as [defaults.alert.jira] when one token serves both.
[connections.example-atlassian]
plugin = "atlassian"
site_url = "https://example.atlassian.net"
cloud_id = "00000000-0000-0000-0000-000000000000"
org_id = "ffffffff-ffff-ffff-ffff-ffffffffffff"
user = "thaum-atlassian-bot@example.com"
api_token = "secret:atlassian-api-token"

[lookup.atlassian]
connection_ref = "example-atlassian"

[defaults.alert.jira]
# Alert plugin does not support connection_ref yet — duplicate site/cloud/user/token to match [connections.example-atlassian].
site_url = "https://example.atlassian.net"
cloud_id = "00000000-0000-0000-0000-000000000000"
user = "thaum-atlassian-bot@example.com"
api_token = "secret:atlassian-api-token"
status_webhook_bearer = ""
responders = []

[bots.database]
name = "Thaum Database"
team_description = "Database"
high_pri_on = false
send_alerts = true
alert_type = "jira"
responders = ["team:DBA"]
emergency_warning_message = ""
token = "secret:thaum_webex_token_database"

[bots.database.alert]
responders = ["team:DBA"]
